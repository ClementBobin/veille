generator client {
  provider = "prisma-client"
  output   = "./generated/client"
}

datasource db {
  provider = "postgres"
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())

  tags           Tag[]
  sources        Source[]
  feedItems      FeedItem[]
  digests        Digest[]
  notes          Note[]
  pipelineEvents PipelineEvent[]
  apiKeys        ApiKey[]
  configs        Config[]
  logs           Log[]
  webhooks       Webhook[]
  themes         Theme[]
}

model Tag {
  id          String   @id @default(cuid())
  userId      String
  name        String
  color       String   @default("#6366f1")
  description String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  feedItems  FeedItemTag[]
  digestTags DigestTag[]

  @@unique([userId, name])
}

model Source {
  id        String     @id @default(cuid())
  userId    String
  name      String
  url       String
  type      SourceType
  active    Boolean    @default(true)
  cache     Boolean    @default(false)
  createdAt DateTime   @default(now())
  lastFetch DateTime?

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  feedItems FeedItem[]

  @@unique([userId, url])
}

enum SourceType {
  RSS
  SCRAPING
  VIDEO
  AUDIO
  SOCIAL
  NEWSLETTER
  WEBHOOK
  FILE
}

model FeedItem {
  id          String    @id @default(cuid())
  userId      String
  title       String
  url         String
  content     String?
  sourceId    String
  publishedAt DateTime?
  fetchedAt   DateTime  @default(now())
  relevant    Boolean   @default(false)
  score       Float?
  processed   Boolean   @default(false)
  tagsHash    String?

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  source           Source            @relation(fields: [sourceId], references: [id])
  tags             FeedItemTag[]
  subjects         SubjectFeedItem[]
  tocEntryArticles TocEntryArticle[]

  @@unique([userId, url])
}

model FeedItemTag {
  feedItemId String
  tagId      String
  feedItem   FeedItem @relation(fields: [feedItemId], references: [id], onDelete: Cascade)
  tag        Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([feedItemId, tagId])
}

model Digest {
  id        String       @id @default(cuid())
  userId    String
  title     String?
  summary   String?
  date      DateTime     @default(now())
  status    DigestStatus @default(PENDING)
  sentAt    DateTime?
  createdAt DateTime     @default(now())

  user     User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  subjects Subject[]
  tags     DigestTag[]
  notes    Note[]
  toc      TocEntry[]
}

model TocEntry {
  id       String @id @default(cuid())
  digestId String
  order    Int    @default(0)
  title    String
  summary  String

  digest   Digest            @relation(fields: [digestId], references: [id], onDelete: Cascade)
  articles TocEntryArticle[]
}

model TocEntryArticle {
  tocEntryId String
  feedItemId String
  tocEntry   TocEntry @relation(fields: [tocEntryId], references: [id], onDelete: Cascade)
  feedItem   FeedItem @relation(fields: [feedItemId], references: [id], onDelete: Cascade)

  @@id([tocEntryId, feedItemId])
}

enum DigestStatus {
  PENDING
  SENT
  SELECTED
  DONE
}

model DigestTag {
  digestId String
  tagId    String
  digest   Digest @relation(fields: [digestId], references: [id], onDelete: Cascade)
  tag      Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([digestId, tagId])
}

model Subject {
  id       String  @id @default(cuid())
  digestId String
  title    String
  summary  String
  selected Boolean @default(false)
  order    Int     @default(0)

  digest    Digest            @relation(fields: [digestId], references: [id], onDelete: Cascade)
  feedItems SubjectFeedItem[]
}

model SubjectFeedItem {
  subjectId  String
  feedItemId String
  subject    Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  feedItem   FeedItem @relation(fields: [feedItemId], references: [id], onDelete: Cascade)

  @@id([subjectId, feedItemId])
}

model Note {
  id         String   @id @default(cuid())
  userId     String
  title      String
  content    String
  digestId   String?
  filename   String
  createdAt  DateTime @default(now())

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  digest Digest? @relation(fields: [digestId], references: [id])
}

model PipelineEvent {
  id        String   @id @default(cuid())
  userId    String
  workflow  String
  status    String
  message   String?
  runId     String?
  branch    String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ApiKey {
  id        String    @id @default(cuid())
  userId    String
  name      String
  keyHash   String    @unique
  lastUsed  DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Webhook {
  id              String    @id @default(cuid())
  userId          String
  name            String
  url             String
  secret          String?
  events          String    @default("pipeline-event,note.created")
  active          Boolean   @default(true)
  lastTriggeredAt DateTime?
  lastStatus      String?
  createdAt       DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Config {
  id        String   @id @default(cuid())
  userId    String
  key       String
  value     String
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
}

model Log {
  id         String   @id @default(cuid())
  userId     String?
  method     String
  path       String
  status     Int
  durationMs Int
  authType   String?
  apiKeyName String?
  error      String?
  type       String   @default("request")
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([path])
  @@index([type])
}

model Theme {
  id                String   @id @default(cuid())
  userId            String
  title             String
  description       String?
  tags              String   @default("[]")
  active            Boolean  @default(true)
  validationCriteria String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, title])
}