generator client {
  provider = "prisma-client"
  output   = "./generated/client"
}

datasource db {
  provider = "sqlite"
}

model Tag {
  id          String   @id @default(cuid())
  name        String   @unique
  color       String   @default("#6366f1")
  description String?
  createdAt   DateTime @default(now())

  feedItems   FeedItemTag[]
  digestTags  DigestTag[]
}

model Source {
  id        String     @id @default(cuid())
  name      String
  url       String     @unique
  type      SourceType
  active    Boolean    @default(true)
  /// Si true : on vérifie si un FeedItem existe déjà pour cette source avant de la renvoyer à n8n
  cache     Boolean    @default(false)
  createdAt DateTime   @default(now())
  lastFetch DateTime?

  feedItems FeedItem[]
}

enum SourceType {
  RSS
  API
  SCRAPING
  VIDEO
}

model FeedItem {
  id          String    @id @default(cuid())
  title       String
  url         String    @unique
  content     String?
  sourceId    String
  publishedAt DateTime?
  fetchedAt   DateTime  @default(now())
  relevant    Boolean   @default(false)
  score       Float?
  processed   Boolean   @default(false)
  /// Hash des tags assignés — permet de détecter si la catégorisation a changé
  tagsHash    String?

  source   Source          @relation(fields: [sourceId], references: [id])
  tags     FeedItemTag[]
  subjects SubjectFeedItem[]
}

model FeedItemTag {
  feedItemId String
  tagId      String
  feedItem   FeedItem @relation(fields: [feedItemId], references: [id], onDelete: Cascade)
  tag        Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([feedItemId, tagId])
}

model Digest {
  id        String       @id @default(cuid())
  date      DateTime     @default(now())
  status    DigestStatus @default(PENDING)
  sentAt    DateTime?
  createdAt DateTime     @default(now())

  subjects Subject[]
  tags     DigestTag[]
  notes    Note[]
}

enum DigestStatus {
  PENDING
  SENT
  SELECTED
  DONE
}

model DigestTag {
  digestId String
  tagId    String
  digest   Digest @relation(fields: [digestId], references: [id], onDelete: Cascade)
  tag      Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([digestId, tagId])
}

model Subject {
  id       String  @id @default(cuid())
  digestId String
  title    String
  summary  String
  selected Boolean @default(false)
  order    Int     @default(0)

  digest   Digest            @relation(fields: [digestId], references: [id], onDelete: Cascade)
  feedItems SubjectFeedItem[]
}

model SubjectFeedItem {
  subjectId  String
  feedItemId String
  subject    Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  feedItem   FeedItem @relation(fields: [feedItemId], references: [id], onDelete: Cascade)

  @@id([subjectId, feedItemId])
}

model Note {
  id         String   @id @default(cuid())
  title      String
  content    String
  digestId   String?
  filename   String
  exportedTo String   @default("[]")
  createdAt  DateTime @default(now())

  digest Digest? @relation(fields: [digestId], references: [id])
}

/// Suivi des événements de pipeline n8n — un enregistrement par étape WF1→WF5
model PipelineEvent {
  id        String   @id @default(cuid())
  workflow  String   /// "WF1", "WF2", "WF3", "WF4", "WF5"
  status    String   /// "started" | "done" | "error"
  message   String?
  runId     String?
  branch    String?
  createdAt DateTime @default(now())
}
